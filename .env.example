# ---------------------------------------------------------------------------
# GRCen configuration. Copy to `.env` and adjust. All values shown are the
# built-in defaults (from src/grcen/config.py) unless noted otherwise.
# ---------------------------------------------------------------------------

# Database
DATABASE_URL=postgresql+asyncpg://grcen:grcen@localhost:5432/grcen

# App
APP_NAME=GRCen
DEBUG=true
# REQUIRED in production: the server refuses to start with DEBUG=false while
# this is left at the default. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-random-secret-key
# Public base URL used when building links in outbound emails.
APP_BASE_URL=http://localhost:8000

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
# Comma-separated allowlist of accepted upload content types.
# ALLOWED_UPLOAD_TYPES=application/pdf,image/png,image/jpeg,image/gif,text/plain,text/csv,application/json,application/xml,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Session management
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_MINUTES=480
# Cap concurrent sessions per user. 0 = unlimited; oldest evicted when hit.
SESSION_MAX_CONCURRENT=5
# Per-role overrides: -1 means "use the global default".
SESSION_MAX_CONCURRENT_ADMIN=3
SESSION_MAX_CONCURRENT_AUDITOR=-1
SESSION_MAX_CONCURRENT_EDITOR=-1
SESSION_MAX_CONCURRENT_VIEWER=-1

# Login lockout + spraying protection
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT_SECONDS=2.0

# Roles that MUST have TOTP enabled to log in (comma-separated: admin,editor,
# viewer,auditor). Empty = no enforcement. SSO users are exempt.
MFA_REQUIRED_FOR_ROLES=

# General API rate limiting. Sliding window per (key, bucket); key is API token
# id, then session id, then client IP. Buckets: read (GET/HEAD/OPTIONS) + write.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_READ_PER_MINUTE=600
RATE_LIMIT_WRITE_PER_MINUTE=120
# Per-route overrides: "<path-prefix>:<read>:<write>,..." (longest prefix wins).
# RATE_LIMIT_ROUTE_OVERRIDES=/api/imports:30:30,/api/exports:60:60

# TLS — set both to enable direct HTTPS termination (see configure_https.md)
# SSL_CERTFILE=/certs/fullchain.pem
# SSL_KEYFILE=/certs/privkey.pem

# Encryption at rest — base64url-encoded 32-byte keys. Empty = disabled.
# Generate with: grcen generate-key  (see configure_encryption.md)
# ENCRYPTION_KEY=
# Previous key, decrypt-only, used during zero-downtime key rotation.
# ENCRYPTION_KEY_RETIRED=
