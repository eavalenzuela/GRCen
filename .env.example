# Database
DATABASE_URL=postgresql+asyncpg://grcen:grcen@localhost:5432/grcen

# App
SECRET_KEY=change-me-to-a-random-secret-key
APP_NAME=GRCen
DEBUG=true

# File uploads
UPLOAD_DIR=./uploads

# TLS — set both to enable direct HTTPS termination (see configure_https.md)
# SSL_CERTFILE=/certs/fullchain.pem
# SSL_KEYFILE=/certs/privkey.pem

# Encryption at rest — generate with: grcen generate-key (see configure_encryption.md)
# ENCRYPTION_KEY=
